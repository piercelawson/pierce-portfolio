---
layout: base.njk
pageTitle: "{{ title }}"
---

{% block head %}
<style>
  /* ═══════════════════════════════════════
     PROJECT HERO
     ═══════════════════════════════════════ */
  .project-hero {
    min-height: 65vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 3rem;
    position: relative;
    overflow: hidden;
  }

  .project-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .project-hero-bg img {
    width: 100%; height: 100%;
    object-fit: cover;
    filter: brightness(0.35) saturate(0.8);
  }

  .project-hero-bg .fallback-bg {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, #1a1a2e 0%, #0f3460 50%, #16213e 100%);
  }

  .project-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, var(--bg) 0%, transparent 50%);
    z-index: 1;
  }

  .project-hero-content {
    position: relative;
    z-index: 2;
    max-width: 900px;
  }

  .project-hero-cat {
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
    animation: fadeUp 0.6s ease both 0.3s;
  }

  .project-hero h1 {
    font-family: var(--serif);
    font-size: clamp(2.8rem, 7vw, 5rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.03em;
    animation: fadeUp 0.6s ease both 0.45s;
  }

  .project-meta {
    display: flex;
    gap: 3rem;
    margin-top: 1.8rem;
    animation: fadeUp 0.6s ease both 0.6s;
  }

  .project-meta dt {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.2rem;
  }

  .project-meta dd {
    font-size: 0.95rem;
    color: var(--text-muted);
  }

  /* ═══════════════════════════════════════
     HERO MEDIA — VIDEO
     ═══════════════════════════════════════ */
  .hero-media {
    max-width: 1100px;
    margin: -2rem auto 0;
    padding: 0 3rem;
    position: relative;
    z-index: 3;
  }

  .hero-video-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    background: #000;
    border: 1px solid var(--border);
    overflow: hidden;
    box-shadow: 0 30px 80px rgba(0,0,0,0.6);
  }

  .hero-video-wrap iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  .hero-video-wrap.video-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  /* ═══════════════════════════════════════
     HERO MEDIA — GALLERY
     ═══════════════════════════════════════ */
  .hero-gallery-wrap {
    position: relative;
    margin: -2rem 0 0;
    z-index: 3;
  }

  .hero-gallery {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    padding: 0 3rem 1.5rem;
    cursor: grab;
    scrollbar-width: none;
  }

  .hero-gallery::-webkit-scrollbar { display: none; }
  .hero-gallery.is-dragging { cursor: grabbing; scroll-behavior: auto; }

  .gallery-slide {
    flex: 0 0 auto;
    scroll-snap-align: center;
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
    transition: border-color 0.3s ease;
  }

  .gallery-slide:hover {
    border-color: rgba(201, 255, 87, 0.15);
  }

  /* First slide is larger */
  .gallery-slide:first-child {
    width: min(85vw, 900px);
    aspect-ratio: 16/10;
  }

  .gallery-slide:not(:first-child) {
    width: min(70vw, 700px);
    aspect-ratio: 16/10;
  }

  .gallery-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out);
  }

  .gallery-slide:hover img {
    transform: scale(1.03);
  }

  .gallery-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 3rem 1.5rem 1.2rem;
    background: linear-gradient(to top, rgba(10,10,10,0.85) 0%, transparent 100%);
    font-size: 0.85rem;
    color: var(--text-muted);
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .gallery-slide:hover .gallery-caption {
    opacity: 1;
    transform: translateY(0);
  }

  /* Gallery indicators */
  .gallery-indicators {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem 0 0;
  }

  .gallery-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--text-muted);
    opacity: 0.3;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: opacity 0.3s, background 0.3s, transform 0.3s;
  }

  .gallery-dot.active {
    opacity: 1;
    background: var(--accent);
    transform: scale(1.4);
  }

  /* Gallery nav arrows */
  .gallery-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 5;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(10, 10, 10, 0.7);
    border: 1px solid rgba(255,255,255,0.1);
    color: var(--text);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.3s, border-color 0.3s, transform 0.2s;
    backdrop-filter: blur(8px);
  }

  .gallery-nav:hover {
    background: rgba(10, 10, 10, 0.9);
    border-color: var(--accent);
    transform: translateY(-50%) scale(1.05);
  }

  .gallery-nav svg { width: 18px; height: 18px; }
  .gallery-nav--prev { left: 1rem; }
  .gallery-nav--next { right: 1rem; }

  .gallery-counter {
    text-align: center;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-top: 0.5rem;
  }

  .gallery-counter .current { color: var(--accent); }

  /* ═══════════════════════════════════════
     PROJECT BODY
     ═══════════════════════════════════════ */
  .project-body {
    max-width: 820px;
    margin: 0 auto;
    padding: 4rem 3rem 2rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 3rem;
    transition: color 0.3s;
  }

  .back-link:hover { color: var(--accent); }
  .back-link svg { width: 14px; height: 14px; transition: transform 0.3s; }
  .back-link:hover svg { transform: translateX(-4px); }

  .project-description {
    font-size: 1.3rem;
    color: var(--text);
    line-height: 1.7;
    margin-bottom: 3rem;
    font-weight: 300;
    border-left: 2px solid var(--accent);
    padding-left: 1.5rem;
  }

  .project-content {
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.85;
  }

  .project-content p { margin-bottom: 1.5rem; }
  .project-content strong { color: var(--text); font-weight: 500; }
  .project-content h2, .project-content h3 {
    font-family: var(--serif);
    color: var(--text);
    margin: 2.5rem 0 1rem;
    font-weight: 400;
  }
  .project-content h2 { font-size: 1.8rem; }
  .project-content h3 { font-size: 1.4rem; }
  .project-content img { width: 100%; margin: 2rem 0; border: 1px solid var(--border); }

  /* ═══════════════════════════════════════
     PROCESS SECTION
     ═══════════════════════════════════════ */
  .process-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 3rem 6rem;
  }

  .process-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .process-header h2 {
    font-family: var(--serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    white-space: nowrap;
  }

  .process-header .line { flex: 1; height: 1px; background: var(--border); }

  .process-header .num {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    white-space: nowrap;
  }

  .process-grid { display: grid; grid-template-columns: 1fr; gap: 2rem; }

  .process-item {
    background: var(--bg-card);
    border: 1px solid var(--border);
    overflow: hidden;
    transition: border-color 0.4s ease;
  }

  .process-item:hover { border-color: rgba(201, 255, 87, 0.15); }

  .process-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .process-media {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16/10;
    background: var(--bg);
    cursor: pointer;
  }

  .process-media img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out), filter 0.4s ease;
    filter: brightness(0.9) saturate(0.9);
  }

  .process-item:hover .process-media img {
    transform: scale(1.04);
    filter: brightness(1) saturate(1);
  }

  .process-media video {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: opacity 0.3s ease;
  }

  .process-media .play-indicator {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 60px; height: 60px;
    border-radius: 50%;
    background: rgba(10, 10, 10, 0.7);
    border: 1px solid rgba(201, 255, 87, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.3s ease, transform 0.3s ease;
    pointer-events: none;
  }

  .process-media .play-indicator svg { width: 20px; height: 20px; color: var(--accent); margin-left: 3px; }
  .process-item:hover .play-indicator { opacity: 0; transform: translate(-50%, -50%) scale(0.8); }

  .process-text { padding: 1.8rem 2rem; }

  .process-text .step-num {
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .process-text h3 {
    font-family: var(--serif);
    font-size: 1.4rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .process-text p { color: var(--text-muted); font-size: 0.95rem; line-height: 1.7; }

  /* ═══════════════════════════════════════
     FEATURED PROJECTS
     ═══════════════════════════════════════ */
  .featured-section {
    padding: 6rem 3rem 8rem;
    background: var(--bg-elevated);
    border-top: 1px solid var(--border);
  }

  .featured-header {
    max-width: 1400px;
    margin: 0 auto 3.5rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .featured-header h2 {
    font-family: var(--serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  .featured-header a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-bottom: 1px solid var(--text-muted);
    padding-bottom: 2px;
    transition: color 0.3s, border-color 0.3s;
  }

  .featured-header a:hover { color: var(--accent); border-color: var(--accent); }

  .featured-grid {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .featured-card {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .featured-card .f-thumb {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out), filter 0.6s ease;
    filter: grayscale(30%) brightness(0.8);
  }

  .featured-card:hover .f-thumb {
    transform: scale(1.06);
    filter: grayscale(0%) brightness(1);
  }

  .featured-card .f-placeholder { width: 100%; height: 100%; }

  .featured-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10,10,10,0.9) 0%, transparent 55%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.8rem;
    transition: background 0.4s ease;
  }

  .featured-card:hover .featured-overlay {
    background: linear-gradient(to top, rgba(10,10,10,0.95) 0%, rgba(10,10,10,0.3) 60%);
  }

  .featured-cat {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.3rem;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.3s ease 0.05s, transform 0.3s ease 0.05s;
  }

  .featured-card:hover .featured-cat { opacity: 1; transform: translateY(0); }

  .featured-title {
    font-family: var(--serif);
    font-size: 1.3rem;
    letter-spacing: -0.01em;
    transform: translateY(4px);
    transition: transform 0.3s ease;
  }

  .featured-card:hover .featured-title { transform: translateY(0); }

  /* ═══════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════ */
  @media (max-width: 900px) {
    .project-hero { min-height: 50vh; padding: 2.5rem 1.5rem; }
    .hero-media { padding: 0 1.5rem; }
    .hero-gallery { padding: 0 1.5rem 1.5rem; }
    .project-body { padding: 3rem 1.5rem 1.5rem; }
    .process-section { padding: 3rem 1.5rem 4rem; }
    .process-pair { grid-template-columns: 1fr; }
    .featured-section { padding: 4rem 1.5rem 5rem; }
    .featured-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
    .project-meta { gap: 2rem; }
    .gallery-nav { display: none; }
  }

  @media (max-width: 600px) {
    .project-hero { min-height: 45vh; }
    .project-meta { flex-direction: column; gap: 0.8rem; }
    .featured-grid { grid-template-columns: 1fr; }
    .process-text { padding: 1.4rem 1.2rem; }
    .gallery-slide:first-child,
    .gallery-slide:not(:first-child) { width: 90vw; }
  }
</style>
{% endblock %}

<!-- ═══ PROJECT HERO ═══ -->
<section class="project-hero">
  <div class="project-hero-bg">
    {% if hero_image %}
      <img src="{{ hero_image }}" alt="{{ title }}">
    {% elif thumbnail %}
      <img src="{{ thumbnail }}" alt="{{ title }}">
    {% else %}
      <div class="fallback-bg"></div>
    {% endif %}
  </div>
  <div class="project-hero-content">
    <div class="project-hero-cat">{{ category }}</div>
    <h1>{{ title }}</h1>
    <dl class="project-meta">
      {% if client %}
      <div><dt>Client</dt><dd>{{ client }}</dd></div>
      {% endif %}
      {% if year %}
      <div><dt>Year</dt><dd>{{ year }}</dd></div>
      {% endif %}
      <div><dt>Type</dt><dd>{{ category }}</dd></div>
    </dl>
  </div>
</section>

<!-- ═══ HERO MEDIA — VIDEO or GALLERY ═══ -->
{% if project_type == "video" and video_url %}
<div class="hero-media reveal">
  <div class="hero-video-wrap">
    <iframe src="{{ video_url }}" allowfullscreen loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin"></iframe>
  </div>
</div>

{% elif project_type == "video" and not video_url %}
<div class="hero-media reveal">
  <div class="hero-video-wrap video-placeholder">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:48px;height:48px;color:var(--text-muted)"><polygon points="5,3 19,12 5,21" fill="currentColor" opacity="0.3"/></svg>
    <span style="color:var(--text-muted);font-size:0.85rem;margin-top:0.75rem;letter-spacing:0.08em;text-transform:uppercase">Video Coming Soon</span>
  </div>
</div>

{% elif project_type == "gallery" and gallery and gallery.length %}
<div class="hero-gallery-wrap reveal">
  <div class="hero-gallery" id="heroGallery">
    {% for slide in gallery %}
    <div class="gallery-slide" data-index="{{ loop.index0 }}">
      {% if slide.image %}
        <img src="{{ slide.image }}" alt="{{ slide.alt or title }}" loading="{% if loop.first %}eager{% else %}lazy{% endif %}">
      {% else %}
        <div style="width:100%;height:100%;background:var(--bg-card);display:flex;align-items:center;justify-content:center;">
          <span style="color:var(--text-muted);font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase">Image Pending</span>
        </div>
      {% endif %}
      {% if slide.caption %}
      <div class="gallery-caption">{{ slide.caption }}</div>
      {% endif %}
    </div>
    {% endfor %}
  </div>

  <button class="gallery-nav gallery-nav--prev" aria-label="Previous slide" onclick="scrollGallery(-1)">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
  </button>
  <button class="gallery-nav gallery-nav--next" aria-label="Next slide" onclick="scrollGallery(1)">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
  </button>

  <div class="gallery-indicators" id="galleryDots">
    {% for slide in gallery %}
    <button class="gallery-dot{% if loop.first %} active{% endif %}" data-index="{{ loop.index0 }}" aria-label="Go to slide {{ loop.index }}"></button>
    {% endfor %}
  </div>
  <div class="gallery-counter">
    <span class="current">1</span> / {{ gallery.length }}
  </div>
</div>

{% elif video_url %}
{# Fallback: if project_type not set but video_url exists #}
<div class="hero-media reveal">
  <div class="hero-video-wrap">
    <iframe src="{{ video_url }}" allowfullscreen loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin"></iframe>
  </div>
</div>
{% endif %}

<!-- ═══ PROJECT BODY ═══ -->
<article class="project-body">
  <a href="/" class="back-link transition-link">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    Back to Work
  </a>

  {% if description %}
    <p class="project-description reveal">{{ description }}</p>
  {% endif %}

  <div class="project-content reveal">
    {{ content | safe }}
  </div>
</article>

<!-- ═══ PROCESS GALLERY ═══ -->
{% if process and process.length %}
<section class="process-section">
  <div class="process-header reveal">
    <h2>Process</h2>
    <div class="line"></div>
    <span class="num">{{ process.length }} {% if process.length == 1 %}Item{% else %}Items{% endif %}</span>
  </div>

  <div class="process-grid">
    {% set halfQueue = [] %}
    {% for item in process %}
      {% if item.layout == "half" %}
        {% set halfQueue = (halfQueue.push(item), halfQueue) %}
        {% if halfQueue.length == 2 %}
        <div class="process-pair reveal">
          {% for hItem in halfQueue %}
          <div class="process-item">
            <div class="process-media">
              {% if hItem.media_type == "video" and hItem.video_file %}
                <video class="hover-video" muted loop playsinline preload="none"
                  {% if hItem.video_poster %}poster="{{ hItem.video_poster }}"{% endif %}>
                  <source src="{{ hItem.video_file }}" type="video/mp4">
                </video>
                <div class="play-indicator">
                  <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>
                </div>
              {% elif hItem.image %}
                <img src="{{ hItem.image }}" alt="{{ hItem.caption }}" loading="lazy">
              {% endif %}
            </div>
            <div class="process-text">
              <div class="step-num">Step {{ loop.parent.loop.index }}</div>
              <h3>{{ hItem.caption }}</h3>
              {% if hItem.text %}<p>{{ hItem.text }}</p>{% endif %}
            </div>
          </div>
          {% endfor %}
        </div>
        {% set halfQueue = [] %}
        {% endif %}
      {% else %}
        {% if halfQueue.length > 0 %}
        <div class="process-item reveal">
          {% set fItem = halfQueue[0] %}
          <div class="process-media">
            {% if fItem.media_type == "video" and fItem.video_file %}
              <video class="hover-video" muted loop playsinline preload="none"
                {% if fItem.video_poster %}poster="{{ fItem.video_poster }}"{% endif %}>
                <source src="{{ fItem.video_file }}" type="video/mp4">
              </video>
              <div class="play-indicator">
                <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>
              </div>
            {% elif fItem.image %}
              <img src="{{ fItem.image }}" alt="{{ fItem.caption }}" loading="lazy">
            {% endif %}
          </div>
          <div class="process-text">
            <div class="step-num">Step {{ loop.index - 1 }}</div>
            <h3>{{ fItem.caption }}</h3>
            {% if fItem.text %}<p>{{ fItem.text }}</p>{% endif %}
          </div>
        </div>
        {% set halfQueue = [] %}
        {% endif %}

        <div class="process-item reveal">
          <div class="process-media">
            {% if item.media_type == "video" and item.video_file %}
              <video class="hover-video" muted loop playsinline preload="none"
                {% if item.video_poster %}poster="{{ item.video_poster }}"{% endif %}>
                <source src="{{ item.video_file }}" type="video/mp4">
              </video>
              <div class="play-indicator">
                <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>
              </div>
            {% elif item.image %}
              <img src="{{ item.image }}" alt="{{ item.caption }}" loading="lazy">
            {% endif %}
          </div>
          <div class="process-text">
            <div class="step-num">Step {{ loop.index }}</div>
            <h3>{{ item.caption }}</h3>
            {% if item.text %}<p>{{ item.text }}</p>{% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>
{% endif %}

<!-- ═══ FEATURED PROJECTS ═══ -->
{% set otherFeatured = [] %}
{% for p in collections.featured %}
  {% if p.data.title != title %}
    {% set otherFeatured = (otherFeatured.push(p), otherFeatured) %}
  {% endif %}
{% endfor %}

{% if otherFeatured.length > 0 %}
<section class="featured-section">
  <div class="featured-header reveal">
    <h2>More Work</h2>
    <a href="/#work" class="transition-link">View All</a>
  </div>
  <div class="featured-grid">
    {% set gradients = [
      "linear-gradient(135deg, #1a1a2e, #16213e, #0f3460)",
      "linear-gradient(135deg, #2d1b2e, #1b1b2f, #0d2137)",
      "linear-gradient(135deg, #1a2a1a, #0f1f2e, #1a1a2e)",
      "linear-gradient(135deg, #2e1a1a, #2e1f0f, #2e2a1a)",
      "linear-gradient(135deg, #0f1a2e, #1a0f2e, #2e1a2a)",
      "linear-gradient(135deg, #1a1a1a, #2a2a2a, #1a2a3a)"
    ] %}
    {% for p in otherFeatured | batch(3) | first %}
    <a href="{{ p.url }}" class="featured-card reveal transition-link" style="transition-delay: {{ loop.index0 * 0.1 }}s">
      {% if p.data.thumbnail %}
        <img class="f-thumb" src="{{ p.data.thumbnail }}" alt="{{ p.data.title }}" loading="lazy">
      {% else %}
        <div class="f-thumb f-placeholder" style="background: {{ gradients[loop.index0 % 6] }};"></div>
      {% endif %}
      <div class="featured-overlay">
        <div class="featured-cat">{{ p.data.category }}</div>
        <div class="featured-title">{{ p.data.title }}</div>
      </div>
    </a>
    {% endfor %}
  </div>
</section>
{% endif %}

{% block scripts %}
<script>
  // ─── GALLERY LOGIC ───
  (function() {
    const gallery = document.getElementById('heroGallery');
    if (!gallery) return;

    const slides = gallery.querySelectorAll('.gallery-slide');
    const dots = document.querySelectorAll('.gallery-dot');
    const counter = document.querySelector('.gallery-counter .current');
    let currentIndex = 0;

    // Scroll to specific slide
    window.scrollGallery = function(dir) {
      currentIndex = Math.max(0, Math.min(slides.length - 1, currentIndex + dir));
      slides[currentIndex].scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      updateIndicators(currentIndex);
    };

    // Dot click
    dots.forEach(dot => {
      dot.addEventListener('click', () => {
        currentIndex = parseInt(dot.dataset.index);
        slides[currentIndex].scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
        updateIndicators(currentIndex);
      });
    });

    // Track scroll position for indicators
    let scrollTimeout;
    gallery.addEventListener('scroll', () => {
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(() => {
        const galleryRect = gallery.getBoundingClientRect();
        const centerX = galleryRect.left + galleryRect.width / 2;
        let closest = 0;
        let closestDist = Infinity;
        slides.forEach((slide, i) => {
          const slideRect = slide.getBoundingClientRect();
          const slideCenterX = slideRect.left + slideRect.width / 2;
          const dist = Math.abs(slideCenterX - centerX);
          if (dist < closestDist) { closestDist = dist; closest = i; }
        });
        currentIndex = closest;
        updateIndicators(closest);
      }, 60);
    });

    function updateIndicators(idx) {
      dots.forEach((d, i) => d.classList.toggle('active', i === idx));
      if (counter) counter.textContent = idx + 1;
    }

    // Drag to scroll
    let isDown = false, startX, scrollLeft;
    gallery.addEventListener('mousedown', (e) => {
      isDown = true;
      gallery.classList.add('is-dragging');
      startX = e.pageX - gallery.offsetLeft;
      scrollLeft = gallery.scrollLeft;
    });
    gallery.addEventListener('mouseleave', () => { isDown = false; gallery.classList.remove('is-dragging'); });
    gallery.addEventListener('mouseup', () => { isDown = false; gallery.classList.remove('is-dragging'); });
    gallery.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - gallery.offsetLeft;
      gallery.scrollLeft = scrollLeft - (x - startX) * 1.5;
    });

    // Keyboard nav
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') scrollGallery(-1);
      if (e.key === 'ArrowRight') scrollGallery(1);
    });
  })();
</script>
{% endblock %}
