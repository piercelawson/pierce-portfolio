<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{% if pageTitle %}{{ pageTitle }} — {% endif %}{{ settings.title }}</title>
<meta name="description" content="{{ settings.hero_sub }}">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0a0a;
    --bg-elevated: #111111;
    --bg-card: #161616;
    --text: #e8e4df;
    --text-muted: #8a8580;
    --accent: #c9ff57;
    --accent-dim: rgba(201, 255, 87, 0.08);
    --border: rgba(255,255,255,0.06);
    --serif: 'Instrument Serif', Georgia, serif;
    --sans: 'DM Sans', system-ui, sans-serif;
    --ease-out: cubic-bezier(0.25, 0.46, 0.45, 0.94);
    --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html {
    scroll-behavior: smooth;
    scrollbar-width: thin;
    scrollbar-color: var(--text-muted) var(--bg);
    overflow-x: hidden;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    font-weight: 300;
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* Film grain */
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
    opacity: 0.5;
  }

  a { color: inherit; }
  img { max-width: 100%; display: block; }

  /* ═══════════════════════════════════════
     PAGE TRANSITION OVERLAY
     ═══════════════════════════════════════ */
  .page-transition {
    position: fixed;
    inset: 0;
    z-index: 10000;
    pointer-events: none;
    display: flex;
  }

  .page-transition .col {
    flex: 1;
    background: var(--accent);
    transform: scaleY(0);
    transform-origin: bottom;
  }

  /* Exit: columns grow up */
  body.is-transitioning .page-transition .col {
    animation: colUp 0.35s var(--ease-out) forwards;
  }
  body.is-transitioning .page-transition .col:nth-child(2) { animation-delay: 0.04s; }
  body.is-transitioning .page-transition .col:nth-child(3) { animation-delay: 0.08s; }
  body.is-transitioning .page-transition .col:nth-child(4) { animation-delay: 0.12s; }
  body.is-transitioning .page-transition .col:nth-child(5) { animation-delay: 0.16s; }

  @keyframes colUp {
    0%   { transform: scaleY(0); transform-origin: bottom; }
    100% { transform: scaleY(1); transform-origin: bottom; }
  }

  /* Enter: columns shrink up (on page load) */
  body.is-entering .page-transition .col {
    transform: scaleY(1);
    transform-origin: top;
    animation: colDown 0.35s var(--ease-out) forwards;
  }
  body.is-entering .page-transition .col:nth-child(2) { animation-delay: 0.04s; }
  body.is-entering .page-transition .col:nth-child(3) { animation-delay: 0.08s; }
  body.is-entering .page-transition .col:nth-child(4) { animation-delay: 0.12s; }
  body.is-entering .page-transition .col:nth-child(5) { animation-delay: 0.16s; }

  @keyframes colDown {
    0%   { transform: scaleY(1); transform-origin: top; }
    100% { transform: scaleY(0); transform-origin: top; }
  }

  /* Page content fades in */
  .page-content {
    opacity: 0;
    animation: contentIn 0.4s ease 0.25s forwards;
  }

  @keyframes contentIn {
    to { opacity: 1; }
  }

  /* ═══════════════════════════════════════
     NAV
     ═══════════════════════════════════════ */
  nav {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 100;
    padding: 1.2rem 3rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: linear-gradient(to bottom, rgba(10,10,10,0.9) 0%, rgba(10,10,10,0.6) 60%, transparent 100%);
    transition: padding 0.3s ease, background 0.3s ease;
  }

  nav.scrolled {
    padding-top: 0.8rem;
    padding-bottom: 0.8rem;
    background: rgba(10,10,10,0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav-logo {
    font-family: var(--serif);
    font-size: 1.5rem;
    color: var(--text);
    text-decoration: none;
    letter-spacing: -0.02em;
    transition: opacity 0.3s;
  }

  .nav-logo:hover { opacity: 0.7; }
  .nav-logo span { color: var(--accent); }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
    align-items: center;
  }

  .nav-links a {
    color: var(--text);
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    position: relative;
    padding-bottom: 4px;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0;
    width: 0; height: 1px;
    background: var(--accent);
    transition: width 0.3s ease;
  }

  .nav-links a:hover::after { width: 100%; }

  /* ─── Hamburger → X toggle ─── */
  .menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    z-index: 200;
    width: 36px;
    height: 36px;
    position: relative;
  }

  .menu-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--text);
    position: absolute;
    left: 6px;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.25s ease,
                top 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .menu-toggle span:nth-child(1) { top: 9px; }
  .menu-toggle span:nth-child(2) { top: 17px; }
  .menu-toggle span:nth-child(3) { top: 25px; }

  /* X state */
  .menu-toggle.active span:nth-child(1) {
    top: 17px;
    transform: rotate(45deg);
  }
  .menu-toggle.active span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .menu-toggle.active span:nth-child(3) {
    top: 17px;
    transform: rotate(-45deg);
  }

  /* ═══════════════════════════════════════
     BUTTONS
     ═══════════════════════════════════════ */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.9rem 2.2rem;
    border: 1px solid var(--accent);
    color: var(--accent);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    font-family: var(--sans);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: background 0.3s ease, color 0.3s ease, transform 0.2s ease;
    cursor: pointer;
    background: transparent;
  }

  .btn:hover {
    background: var(--accent);
    color: var(--bg);
    transform: translateY(-2px);
  }

  .btn svg { width: 14px; height: 14px; transition: transform 0.3s ease; }
  .btn:hover svg { transform: translateX(4px); }

  .arrow-icon { width: 14px; height: 14px; }

  /* ═══════════════════════════════════════
     FOOTER
     ═══════════════════════════════════════ */
  footer {
    padding: 3rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--border);
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .footer-links { display: flex; gap: 2rem; list-style: none; }
  .footer-links a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.3s;
  }
  .footer-links a:hover { color: var(--accent); }

  /* ═══════════════════════════════════════
     SCROLL REVEAL
     ═══════════════════════════════════════ */
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ═══════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════ */
  @media (max-width: 900px) {
    nav { padding: 1rem 1.5rem; }
    .nav-links { gap: 1.5rem; }
    footer {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
      padding: 2rem 1.5rem;
    }
  }

  @media (max-width: 600px) {
    .nav-links {
      position: fixed;
      inset: 0;
      background: rgba(10, 10, 10, 0.97);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 2rem;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.35s ease, visibility 0.35s ease;
      z-index: 150;
    }
    .nav-links.show {
      opacity: 1;
      visibility: visible;
    }
    .nav-links a {
      font-size: 1.4rem;
      letter-spacing: 0.12em;
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.3s ease, transform 0.3s ease, color 0.3s;
    }
    .nav-links.show a {
      opacity: 1;
      transform: translateY(0);
    }
    .nav-links.show li:nth-child(1) a { transition-delay: 0.08s; }
    .nav-links.show li:nth-child(2) a { transition-delay: 0.16s; }
    .nav-links.show li:nth-child(3) a { transition-delay: 0.24s; }
    .menu-toggle { display: block; }
  }
</style>
{% block head %}{% endblock %}
</head>
<body class="is-entering">

<!-- PAGE TRANSITION -->
<div class="page-transition">
  <div class="col"></div>
  <div class="col"></div>
  <div class="col"></div>
  <div class="col"></div>
  <div class="col"></div>
</div>

<nav>
  <a href="/" class="nav-logo transition-link">{{ settings.title | split(" ") | first }}<span>.</span></a>
  <ul class="nav-links">
    <li><a href="/#work" class="transition-link">Work</a></li>
    <li><a href="/#about" class="transition-link">About</a></li>
    <li><a href="/#contact" class="transition-link">Contact</a></li>
  </ul>
  <button class="menu-toggle" aria-label="Toggle menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="page-content">
  {{ content | safe }}
</div>

<footer>
  <span>&copy; 2026 {{ settings.title }}</span>
  <ul class="footer-links">
    <li><a href="/#work" class="transition-link">Work</a></li>
    <li><a href="/#about" class="transition-link">About</a></li>
    <li><a href="/#contact" class="transition-link">Contact</a></li>
  </ul>
  <span>{{ settings.location }}</span>
</footer>

<script>
  // ─── PAGE TRANSITIONS ───
  (function() {
    function clearTransitionState() {
      document.body.classList.remove('is-entering', 'is-transitioning');
      // Ensure content is visible
      var pc = document.querySelector('.page-content');
      if (pc) pc.style.opacity = '1';
    }

    // Remove enter class after animation completes
    setTimeout(clearTransitionState, 500);

    // Handle browser back/forward button (bfcache)
    window.addEventListener('pageshow', function(e) {
      if (e.persisted) {
        // Page was restored from bfcache — clear stuck transition
        clearTransitionState();
      }
    });

    // Also handle popstate for SPA-like back navigation
    window.addEventListener('popstate', function() {
      clearTransitionState();
    });

    // Intercept all transition links
    document.addEventListener('click', function(e) {
      const link = e.target.closest('.transition-link');
      if (!link) return;

      const href = link.getAttribute('href');
      if (href.startsWith('#')) return;
      if (href.startsWith('/#') && window.location.pathname === '/') return;

      e.preventDefault();

      // Close mobile menu if open
      document.querySelector('.nav-links').classList.remove('show');
      document.querySelector('.menu-toggle').classList.remove('active');

      document.body.classList.add('is-transitioning');

      setTimeout(() => {
        window.location.href = href;
      }, 400);
    });
  })();

  // ─── HAMBURGER TOGGLE ───
  (function() {
    const toggle = document.querySelector('.menu-toggle');
    const navLinks = document.querySelector('.nav-links');
    if (!toggle || !navLinks) return;

    toggle.addEventListener('click', function() {
      toggle.classList.toggle('active');
      navLinks.classList.toggle('show');
    });

    // Close menu when a link is clicked
    navLinks.querySelectorAll('a').forEach(function(link) {
      link.addEventListener('click', function() {
        toggle.classList.remove('active');
        navLinks.classList.remove('show');
      });
    });
  })();

  // ─── NAV SCROLL SHRINK ───
  (function() {
    var nav = document.querySelector('nav');
    var scrolled = false;
    window.addEventListener('scroll', function() {
      if (window.scrollY > 50 && !scrolled) {
        nav.classList.add('scrolled');
        scrolled = true;
      } else if (window.scrollY <= 50 && scrolled) {
        nav.classList.remove('scrolled');
        scrolled = false;
      }
    });
  })();

  // ─── SCROLL REVEAL ───
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => entry.target.classList.add('visible'), i * 60);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

  // ─── HOVER-PLAY VIDEOS ───
  document.querySelectorAll('.hover-video').forEach(vid => {
    const wrapper = vid.closest('.process-media') || vid.parentElement;
    wrapper.addEventListener('mouseenter', () => {
      vid.play().catch(() => {});
      vid.style.opacity = '1';
    });
    wrapper.addEventListener('mouseleave', () => {
      vid.pause();
      vid.currentTime = 0;
    });
  });
</script>
{% block scripts %}{% endblock %}

</body>
</html>
